---
import type { PhotoEntry } from '../lib/content';
import type { Lang } from '../i18n/ui';
import DateText from './DateText.astro';
import { withBase } from '../i18n/routes';

interface Props {
  photos: PhotoEntry[];
  lang: Lang;
}

const { photos, lang } = Astro.props;

function imageSrc(src: string): string {
  if (src.startsWith('http://') || src.startsWith('https://') || src.startsWith('data:')) {
    return src;
  }

  return withBase(src);
}
---

<div class="photo-timeline">
  {
    photos.map((photo) => (
      <article class="photo-note">
        <div class="photo-grid" aria-label={photo.data.title}>
          {photo.data.images.map((image) => (
            <img
              src={imageSrc(image.src)}
              alt={image.alt}
              width={image.width}
              height={image.height}
              loading="lazy"
              decoding="async"
            />
          ))}
        </div>
        <div class="photo-copy">
          <h2>{photo.data.title}</h2>
          <p class="photo-meta">
            <DateText date={photo.data.date} lang={lang} />
            {photo.data.location && <span>{photo.data.location}</span>}
          </p>
          <p>{photo.data.description}</p>
        </div>
      </article>
    ))
  }
</div>
