---
import SiteHeader from '../components/SiteHeader.astro';
import type { Lang } from '../i18n/ui';
import { ui } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
  section?: 'posts' | 'photos' | 'about';
}

const { title, description, lang, section = 'posts' } = Astro.props;
const text = ui[lang];
const pageTitle = title ? `${title} | ${text.siteTitle}` : text.siteTitle;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'A quiet personal blog for writing and photos.'} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <SiteHeader lang={lang} section={section} />
    <main class="page-shell">
      <slot />
    </main>
  </body>
</html>
