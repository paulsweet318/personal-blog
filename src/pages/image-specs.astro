---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../i18n/routes';

const imageSpecs = [
  {
    title: 'Square 1:1',
    note: '1080 x 1080',
    src: withBase('/images/test/square-1080.svg'),
    width: 1080,
    height: 1080,
  },
  {
    title: 'Landscape 4:3',
    note: '1200 x 900',
    src: withBase('/images/test/landscape-4-3.svg'),
    width: 1200,
    height: 900,
  },
  {
    title: 'Photo 3:2',
    note: '1200 x 800',
    src: withBase('/images/test/photo-3-2.svg'),
    width: 1200,
    height: 800,
  },
  {
    title: 'Wide 16:9',
    note: '1600 x 900',
    src: withBase('/images/test/wide-16-9.svg'),
    width: 1600,
    height: 900,
  },
  {
    title: 'Portrait 9:16',
    note: '900 x 1600',
    src: withBase('/images/test/portrait-9-16.svg'),
    width: 900,
    height: 1600,
  },
  {
    title: 'Panorama 21:9',
    note: '2100 x 900',
    src: withBase('/images/test/panorama-21-9.svg'),
    width: 2100,
    height: 900,
  },
];
---

<BaseLayout lang="en" section="photos" title="Image Specs" noindex>
  <section class="section-heading">
    <h1>Image Specs</h1>
  </section>
  <div class="image-spec-list">
    {
      imageSpecs.map((image) => (
        <article class="image-spec-card">
          <h2>{image.title}</h2>
          <p>{image.note}</p>
          <div class="photo-grid">
            <img
              src={image.src}
              alt={`${image.title} fixture`}
              width={image.width}
              height={image.height}
              loading="eager"
              decoding="async"
            />
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
