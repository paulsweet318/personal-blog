---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DateText from '../../components/DateText.astro';
import LanguageSwitch from '../../components/LanguageSwitch.astro';
import { getPostTranslation, getPosts } from '../../lib/content';
import { postPath } from '../../i18n/routes';

export async function getStaticPaths() {
  const posts = await getPosts('zh');

  return posts.map((post) => ({
    params: { slug: post.data.urlSlug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const translation = await getPostTranslation(post);
---

<BaseLayout lang="zh" section="posts" title={post.data.title} description={post.data.description}>
  <article class="prose">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-detail-meta">
        <DateText date={post.data.date} lang="zh" />
        {post.data.tags.length > 0 && <span>{post.data.tags.join(' / ')}</span>}
      </p>
      <LanguageSwitch href={translation ? postPath('en', translation.data.urlSlug) : undefined} label="English version" />
    </header>
    <Content />
  </article>
</BaseLayout>
